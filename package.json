{
  "name": "pullguard",
  "version": "0.4.0",
  "description": "BYOK pull request review-risk triage for open-source maintainers.",
  "type": "module",
  "bin": {
    "pullguard": "dist/cli/index.js"
  },
  "files": [
    "action.yml",
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "ncc build src/index.ts -o dist --source-map --license licenses.txt && tsc -p tsconfig.cli.json",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladzima/pullguard.git"
  },
  "homepage": "https://github.com/vladzima/pullguard#readme",
  "bugs": {
    "url": "https://github.com/vladzima/pullguard/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
